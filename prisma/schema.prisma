generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  name                String?
  passwordHash        String?        @map("password_hash")
  companyName         String?        @map("company_name")
  phone               String?
  membershipType      MembershipType @default(FREE) @map("membership_type")
  subscriptionActive  Boolean        @default(false) @map("subscription_active")
  subscriptionEndDate DateTime?      @map("subscription_end_date")
  calculationsCount   Int            @default(0) @map("calculations_count")
  freeUsageRemaining  Int            @default(3) @map("free_usage_remaining")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")
  role                UserRole       @default(USER)

  calculations          Calculation[]
  exports               CalculationExport[]
  createdPorts          Port[]              @relation("PortCreatedBy")
  createdCarriers       ShippingCompany[]   @relation("CarrierCreatedBy")
  createdFreeTime       FreeTimeRule[]      @relation("FreeTimeCreatedBy")
  createdTariffs        TariffRule[]        @relation("TariffCreatedBy")
  createdContainerTypes ContainerType[]     @relation("ContainerTypeCreatedBy")

  @@map("users")
}

model Port {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  country   String   @default("TR")
  city      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  creator       User?          @relation("PortCreatedBy", fields: [createdBy], references: [id])
  freeTimeRules FreeTimeRule[]
  tariffRules   TariffRule[]
  calculations  Calculation[]

  @@map("ports")
}

model ShippingCompany {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  country   String?
  website   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  creator       User?          @relation("CarrierCreatedBy", fields: [createdBy], references: [id])
  freeTimeRules FreeTimeRule[]
  tariffRules   TariffRule[]
  calculations  Calculation[]

  @@map("shipping_companies")
}

model FreeTimeRule {
  id                String    @id @default(uuid())
  portId            String    @map("port_id")
  shippingCompanyId String    @map("shipping_company_id")
  containerType     String    @map("container_type")
  freeDays          Int
  effectiveFrom     DateTime  @default(now()) @map("effective_from") @db.Date
  effectiveUntil    DateTime? @map("effective_until") @db.Date
  isActive          Boolean   @default(true) @map("is_active")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         String?   @map("created_by")

  port            Port            @relation(fields: [portId], references: [id], onDelete: Cascade)
  shippingCompany ShippingCompany @relation(fields: [shippingCompanyId], references: [id], onDelete: Cascade)
  creator         User?           @relation("FreeTimeCreatedBy", fields: [createdBy], references: [id])

  @@unique([portId, shippingCompanyId, containerType, effectiveFrom])
  @@map("free_time_rules")
}

model TariffRule {
  id                String    @id @default(uuid())
  portId            String    @map("port_id")
  shippingCompanyId String    @map("shipping_company_id")
  containerType     String    @map("container_type")
  tier1DaysFrom     Int       @default(1) @map("tier_1_days_from")
  tier1DaysTo       Int       @default(5) @map("tier_1_days_to")
  tier1PricePerDay  Decimal   @map("tier_1_price_per_day") @db.Decimal(10, 2)
  tier2DaysFrom     Int       @default(6) @map("tier_2_days_from")
  tier2DaysTo       Int       @default(10) @map("tier_2_days_to")
  tier2PricePerDay  Decimal   @map("tier_2_price_per_day") @db.Decimal(10, 2)
  tier3DaysFrom     Int       @default(11) @map("tier_3_days_from")
  tier3PricePerDay  Decimal   @map("tier_3_price_per_day") @db.Decimal(10, 2)
  currency          String    @default("TRY")
  effectiveFrom     DateTime  @default(now()) @map("effective_from") @db.Date
  effectiveUntil    DateTime? @map("effective_until") @db.Date
  isActive          Boolean   @default(true) @map("is_active")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         String?   @map("created_by")

  port            Port            @relation(fields: [portId], references: [id], onDelete: Cascade)
  shippingCompany ShippingCompany @relation(fields: [shippingCompanyId], references: [id], onDelete: Cascade)
  creator         User?           @relation("TariffCreatedBy", fields: [createdBy], references: [id])

  @@unique([portId, shippingCompanyId, containerType, effectiveFrom])
  @@map("tariff_rules")
}

model Calculation {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  portId            String    @map("port_id")
  shippingCompanyId String    @map("shipping_company_id")
  containerId       String    @map("container_id")
  containerType     String    @map("container_type")
  departureDate     DateTime  @map("departure_date") @db.Date
  gateInDate        DateTime? @map("gate_in_date") @db.Date
  freeDays          Int       @map("free_days")
  freeUntilDate     DateTime  @map("free_until_date") @db.Date
  chargeableDays    Int       @default(0) @map("chargeable_days")
  totalCharge       Decimal   @default(0) @map("total_charge") @db.Decimal(10, 2)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  ipAddress         String?   @map("ip_address")

  user            User?               @relation(fields: [userId], references: [id])
  port            Port                @relation(fields: [portId], references: [id])
  shippingCompany ShippingCompany     @relation(fields: [shippingCompanyId], references: [id])
  exports         CalculationExport[]

  @@map("calculations")
}

model CalculationExport {
  id            String     @id @default(uuid())
  calculationId String     @map("calculation_id")
  userId        String?    @map("user_id")
  type          ExportType
  recipient     String?
  status        String     @default("success")
  createdAt     DateTime   @default(now()) @map("created_at")

  calculation Calculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])

  @@index([calculationId])
  @@index([userId])
  @@map("calculation_exports")
}

model ContainerType {
  id           String   @id @default(uuid())
  code         String   @unique
  label        String
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by")

  creator User? @relation("ContainerTypeCreatedBy", fields: [createdBy], references: [id])

  @@map("container_types")
}

model FreeUsageTracking {
  id             String   @id @default(uuid())
  identifier     String
  identifierType String   @map("identifier_type")
  usageCount     Int      @default(1) @map("usage_count")
  lastUsedAt     DateTime @default(now()) @map("last_used_at")
  expiresAt      DateTime @map("expires_at")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("free_usage_tracking")
}

enum ExportType {
  PDF
  EMAIL
}

enum MembershipType {
  FREE
  PREMIUM
  CORPORATE
}

enum UserRole {
  USER
  ADMIN
}
