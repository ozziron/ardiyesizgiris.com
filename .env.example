# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ardiyesizgiris"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend) — optional. Until you have a real account & verified
# domain, leave RESEND_API_KEY empty (or as the "re_xxxxx" placeholder)
# and the API will return a friendly "yakinda aktif olacak" message
# instead of crashing.
#
# Activation steps when ready:
#   1. Create a Resend account: https://resend.com
#   2. Verify your sending domain (e.g. ardiyesizgiris.com)
#   3. Generate an API key and paste it below as RESEND_API_KEY
#   4. Set EMAIL_FROM to the verified address
#   5. Restart the server — no code change needed.
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="noreply@ardiyesizgiris.com"

# When "true", the server skips Resend entirely and logs the composed
# email to the console. Useful for local UI testing before the domain
# is verified. Leave empty/false in production.
EMAIL_DRY_RUN="false"

# Stripe Premium billing. Use a recurring Price ID from Stripe Billing.
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_PREMIUM_PRICE_ID="price_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Optional: Analytics, CDN, etc
# NEXT_PUBLIC_ANALYTICS_ID=""
